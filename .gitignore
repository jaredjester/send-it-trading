# Secrets
.env

# Runtime data — generated at runtime, never commit these
data/*
!data/.gitkeep
state/*
!state/.gitkeep
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Junk
*.bak
*.bak.*
.DS_Store
._*

# Evolution runtime outputs
evolution/workers/*/state/*
evolution/workers/*/logs/*
evolution/results/*
evolution/champion.json
!evolution/workers/*/state/.gitkeep
!evolution/workers/*/logs/.gitkeep
!evolution/results/.gitkeep
# Track worker eval configs (these are version-controlled defaults)
!evolution/workers/*/eval/live_config.json

# Track worker personality configs
!evolution/workers/*/eval/live_config.json

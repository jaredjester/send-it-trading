# ─── Send It Trading — Configuration ────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Alpaca API (required) ───────────────────────────────────────────────────
# All three key vars are set to the same value — different components use
# different env var names (engine uses ALPACA_API_KEY, bot uses ALPACA_API_LIVE_KEY)
ALPACA_API_KEY=your_live_key_here
ALPACA_API_LIVE_KEY=your_live_key_here
APCA_API_KEY_ID=your_live_key_here

ALPACA_API_SECRET=your_secret_here
APCA_API_SECRET_KEY=your_secret_here

# Paper trading mode
# ALPACA_PAPER=false   ← read by dashboard + engine
# PAPER_MODE=false     ← read by bot/main.py specifically

# ─── Telegram Alerts (optional) ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Dashboard ───────────────────────────────────────────────────────────────
# DASHBOARD_PORT=5555
# BOT_SERVICE=send-it-engine

# ─── Directory overrides (all default to subdirs of repo root) ───────────────
# DATA_DIR=./data              ← intel files (bot writes here, engine+dashboard reads)
# STATE_DIR=./engine/state     ← runtime state (plans, trade memory, battle plan)
# LOG_DIR=./engine/logs        ← trading logs
# EVAL_DIR=./engine/evaluation ← RL bandit + live config

# ─── Send It Trading — Configuration ────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Alpaca API (required) ──────────────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Paper trading mode (true = paper, false = live)
ALPACA_PAPER=false

# ─── Telegram Alerts (optional) ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Dashboard ───────────────────────────────────────────────────────────────
# Port for the web dashboard (default: 5555)
# DASHBOARD_PORT=5555

# Systemd service name to monitor (default: send-it-engine)
# BOT_SERVICE=send-it-engine

# ─── Directory overrides (optional — all default to repo root subdirs) ───────
# DATA_DIR=./data          ← intel files written by bot/, read by dashboard/
# STATE_DIR=./state        ← runtime state (plans, trade memory, battle plan)
# LOG_DIR=./logs           ← trading logs
# EVAL_DIR=./engine/evaluation  ← RL bandit + live config

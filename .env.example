# ─── Send It Trading — Environment Config ───────────────────────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# ─── Alpaca API (required) ───────────────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Use paper trading? (true/false, default: false)
# ALPACA_PAPER=false

# ─── Dashboard ───────────────────────────────────────────────────────────────
# Port for the web dashboard (default: 5555)
# DASHBOARD_PORT=5555

# Systemd service name for the trading bot (default: mybot)
# BOT_SERVICE=mybot

# ─── Data Directories (optional overrides) ───────────────────────────────────
# All default to subdirectories of the repo root.
# Override if your data lives elsewhere.

# DATA_DIR=./data          # Intel files (news_intel.json, insider_intel.json, etc.)
# STATE_DIR=./state        # Runtime state (plans, trade memory, battle plan)
# LOG_DIR=./logs           # Trading logs
# EVAL_DIR=./evaluation    # RL/eval state (threshold_bandit.json, live_config.json)

# ─── Telegram Notifications (optional) ───────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

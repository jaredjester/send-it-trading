# ─── Send It Trading — .env Template ───────────────────────────────────────
# Copy then edit: cp .env.example .env

# ─── Alpaca Credentials (single source of truth) ───────────────────────────
COMPOSE_PROJECT_NAME=send-it-trading
ALPACA_MODE=live                     # live | paper

ALPACA_LIVE_KEY=your_live_key_here
ALPACA_LIVE_SECRET=your_live_secret_here
ALPACA_LIVE_BASE=https://api.alpaca.markets

ALPACA_PAPER_KEY=your_paper_key_here
ALPACA_PAPER_SECRET=your_paper_secret_here
ALPACA_PAPER_BASE=https://paper-api.alpaca.markets

# Optional: override data API (default https://data.alpaca.markets)
# ALPACA_DATA_BASE=https://data.alpaca.markets

# ALPACA LEGACY VARS ARE AUTO-POPULATED
# alpaca_env.bootstrap() injects APCA_API_KEY_ID, ALPACA_API_SECRET, etc.

# ─── Telegram Alerts ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Directory Overrides (defaults are relative to repo root) ───────────────
# DATA_DIR=./data
# STATE_DIR=./engine/state
# LOG_DIR=./engine/logs
# EVAL_DIR=./engine/evaluation

# ─── Dashboard ──────────────────────────────────────────────────────────────
# DASHBOARD_PORT=5555
# BOT_SERVICE=send-it-engine
# DASHBOARD_SERVICES=send-it-bot,send-it-engine,send-it-dashboard
# DASHBOARD_LOG_LINES=60
